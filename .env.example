# Legacy DeepSeek key (kept for reference, no longer the default provider)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# OpenRouter API (shared key with manor-multi-agent — used for summarization & speaker ID)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI API (for Whisper transcription only — OpenRouter does not proxy Whisper)
OPENAI_API_KEY=your-openai-api-key-here

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://meeting_user:meeting_password@postgres:5432/meeting_notes

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO

# Storage Configuration
STORAGE_DIR=./storage/meetings

# CORS Origins (comma-separated, used by backend)
CORS_ORIGINS=http://localhost:9002,http://localhost:3000

# Storage (default: local filesystem)
# Set to "minio" to use MinIO object storage
STORAGE_BACKEND=local
# MINIO_ENDPOINT=localhost:9012
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=minutes-audio
# MINIO_SECURE=false
