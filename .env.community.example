# Meeting Note Taker — Community Edition
# Copy to .env and fill in your API keys

# Required: OpenAI key for Whisper speech-to-text
OPENAI_API_KEY=sk-your-openai-key-here

# Required: LLM key for summarization (OpenRouter recommended, or use same OpenAI key)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Optional: Override default model (default: moonshotai/kimi-k2.5)
# Options: gpt4o, claude-sonnet, gemini, deepseek, kimi
# LLM_MODEL=gpt4o

# Database (defaults work with docker-compose)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meeting_notes

# JWT secret (change this!)
JWT_SECRET=change-me-to-a-random-string

# Default admin account (created automatically on first startup)
# Change these before deploying to a shared environment
ADMIN_EMAIL=admin@minutes.local
ADMIN_PASSWORD=admin

# Redis
REDIS_URL=redis://redis:6379/0

# Storage (default: local filesystem)
# Set to "minio" to use MinIO object storage
STORAGE_BACKEND=local
# MINIO_ENDPOINT=localhost:9012
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=minutes-audio
# MINIO_SECURE=false
